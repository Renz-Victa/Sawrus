# Sawrus API — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

PORT=3001
NODE_ENV=development

# hCaptcha secret key — get from https://dashboard.hcaptcha.com
# The key below is the test secret (works with sitekey 10000000-ffff-ffff-ffff-000000000001)
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# Comma-separated allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://sawrus.com,https://www.sawrus.com

# SQLite database path (created automatically)
DB_PATH=./data/contacts.db
