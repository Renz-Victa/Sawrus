# Sawrus API — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.
# hCaptcha config lives in two places:
# - contact.html meta tag `sawrus-hcaptcha-sitekey` for the frontend site key
# - .env `HCAPTCHA_SECRET` for the backend secret key

PORT=3001
NODE_ENV=development

# ── Self-hosted CAPTCHA secret ────────────────────────────────
# Use the secret key paired with the frontend site key configured in contact.html.
HCAPTCHA_SECRET=replace_with_your_hcaptcha_secret_key_here

# ── CORS allowed origins ──────────────────────────────────────
# Comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://sawrus.com,https://www.sawrus.com

# ── SQLite database path (created automatically) ──────────────
DB_PATH=./data/contacts.db
